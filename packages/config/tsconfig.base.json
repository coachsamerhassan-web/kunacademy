{
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@kunacademy/*": ["../../packages/*/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
