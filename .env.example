# ============================================================================
# KUN ACADEMY — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================================

# ── SUPABASE (Required for all features) ──
# Create a free Supabase project at https://supabase.com
# Go to Project Settings > API to find these values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (for server-side operations, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── STRIPE PAYMENTS (Required for Wave 2) ──
# Get keys from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PAYTABS GATEWAY (AED/Gulf payments) ──
# Test keys from PayTabs merchant dashboard
PAYTABS_SERVER_KEY=...
PAYTABS_PROFILE_ID=...

# ── TABBY BNPL (Buy Now Pay Later) ──
# Test keys from Tabby Dashboard
TABBY_PUBLIC_KEY=pk_test_...
TABBY_SECRET_KEY=sk_test_...

# ── EMAIL (Resend transactional) ──
# Create free account at https://resend.com
RESEND_API_KEY=re_...

# ── ANALYTICS ──
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (conversion tracking)
NEXT_PUBLIC_META_PIXEL_ID=123456789...

# Meta CAPI (server-side event tracking)
META_CAPI_ACCESS_TOKEN=...

# ── BUNNY.NET VIDEO HOSTING (LMS video delivery) ──
# Create a Stream library at https://dash.bunny.net/stream
NEXT_PUBLIC_BUNNY_LIBRARY_ID=
BUNNY_API_KEY=

# ── DEPLOYMENT ──
# Hostinger Cloud Startup (or leave blank for local development)
# No special vars needed — GitHub auto-deploy handles it
