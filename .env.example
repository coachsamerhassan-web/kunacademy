# ============================================================================
# KUN ACADEMY — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================================

# ── DATABASE (PostgreSQL via Drizzle ORM) ──
# Local dev: postgres://user:pass@localhost:5432/kunacademy
# Staging/production: see DEPLOYMENT.md for VPS connection string
DATABASE_URL=postgres://user:password@localhost:5432/kunacademy

# ── LOCAL FILE STORAGE ──
# Directory where uploaded files are stored on disk.
# Dev: leave blank (defaults to <repo-root>/storage/)
# Staging/Production: /var/www/kunacademy/shared/storage
STORAGE_DIR=

# Public URL prefix for stored files served by Nginx / Next.js API.
# Dev: /api/storage
# Staging/Production: https://kuncoaching.me/storage
NEXT_PUBLIC_STORAGE_URL=/api/storage

# ── STRIPE PAYMENTS (Required for Wave 2) ──
# Get keys from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Shared secret for /api/webhooks/auth — send as x-auth-webhook-secret header (RS-04)
AUTH_WEBHOOK_SECRET=

# ── PAYTABS GATEWAY (AED/Gulf payments) ──
# Test keys from PayTabs merchant dashboard
PAYTABS_SERVER_KEY=...
PAYTABS_PROFILE_ID=...

# ── TABBY BNPL (Buy Now Pay Later) ──
# Test keys from Tabby Dashboard
TABBY_PUBLIC_KEY=pk_test_...
TABBY_SECRET_KEY=sk_test_...

# ── EMAIL (Resend transactional) ──
# Create free account at https://resend.com
RESEND_API_KEY=re_...

# ── ANALYTICS ──
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (conversion tracking)
NEXT_PUBLIC_META_PIXEL_ID=123456789...

# Meta CAPI (server-side event tracking)
META_CAPI_ACCESS_TOKEN=...

# ── BUNNY.NET VIDEO HOSTING (LMS video delivery) ──
# Create a Stream library at https://dash.bunny.net/stream
NEXT_PUBLIC_BUNNY_LIBRARY_ID=
BUNNY_API_KEY=

# ── TELEGRAM ALERTS (internal team notifications) ──
# Bot token from @BotFather — used by payment webhooks + error alerts
TELEGRAM_BOT_TOKEN=
# Chat IDs for each team member (get via @userinfobot or API)
TELEGRAM_CHAT_SAMER=
TELEGRAM_CHAT_AMIN=
TELEGRAM_CHAT_NASHIT=

# ── COACH PAYOUT ENCRYPTION ──
# AES-256-GCM key for encrypting coach bank details at rest (manual_bank method).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (= 32 bytes). NEVER commit the real key.
# Server-side ONLY — must never be prefixed with NEXT_PUBLIC_
COACH_ENCRYPTION_KEY=

# ── STRIPE CONNECT (Coach payouts via Stripe) ──
# Required for coaches who onboard via Stripe Connect OAuth flow.
# Get from Stripe Dashboard > Connect > Settings > Client ID
STRIPE_CONNECT_CLIENT_ID=

# ── DEPLOYMENT ──
# VPS self-hosted on kuncoaching.me (staging) and kunacademy.com (production)
# See DEPLOYMENT.md for full deployment guide including Nginx and PM2 config.
# next build --output standalone — binary is deployed to /var/www/kunacademy/current/
